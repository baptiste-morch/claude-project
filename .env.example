# Mot de passe familial partagé. À transmettre à chaque membre de la famille.
FAMILY_PASSWORD=changeme

# Supabase — récupère ces valeurs dans Project Settings > API Keys.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Nouvelle clé secret (depuis novembre 2025) au format sb_secret_...
# Pour les anciens projets, l'ancienne service_role JWT (eyJ...) reste acceptée.
SUPABASE_SECRET_KEY=sb_secret_...

# TMDB (films + séries). Crée une clé API gratuite sur https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# IGDB / Twitch (jeux vidéo). Enregistre une app sur https://dev.twitch.tv/console/apps
# (OAuth Client Credentials Flow). Récupère Client ID + Client Secret.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Google Books — optionnel. La recherche basique fonctionne sans clé.
# GOOGLE_BOOKS_API_KEY=

# YouTube/Vimeo : aucun key nécessaire, oEmbed public.
